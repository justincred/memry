{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "../../packages/contracts/src/**/*",
    "../../packages/domain-inbox/src/**/*",
    "../../packages/domain-tasks/src/**/*",
    "../../packages/db-schema/src/**/*",
    "../../packages/storage-data/src/**/*",
    "../../packages/rpc/src/**/*",
    "../../packages/shared/src/**/*"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@memry/contracts": ["../../packages/contracts/src/index.ts"],
      "@memry/contracts/*": ["../../packages/contracts/src/*"],
      "@memry/domain-inbox": ["../../packages/domain-inbox/src/index.ts"],
      "@memry/domain-inbox/*": ["../../packages/domain-inbox/src/*"],
      "@memry/domain-tasks": ["../../packages/domain-tasks/src/index.ts"],
      "@memry/domain-tasks/*": ["../../packages/domain-tasks/src/*"],
      "@memry/db-schema": ["../../packages/db-schema/src/index.ts"],
      "@memry/db-schema/*": ["../../packages/db-schema/src/*"],
      "@memry/storage-data": ["../../packages/storage-data/src/index.ts"],
      "@memry/storage-data/*": ["../../packages/storage-data/src/*"],
      "@memry/rpc": ["../../packages/rpc/src/index.ts"],
      "@memry/rpc/*": ["../../packages/rpc/src/*"],
      "@memry/shared": ["../../packages/shared/src/index.ts"],
      "@memry/shared/*": ["../../packages/shared/src/*"],
      "@main/database/queries/notes": ["./src/main/database/queries/notes/index.ts"],
      "@main/database/queries/settings": ["./src/main/database/queries/settings.ts"],
      "@main/database/queries/tasks": ["./src/main/database/queries/tasks.ts"],
      "@main/*": ["./src/main/*"],
      "@renderer/*": ["./src/renderer/src/*"],
      "@/*": ["./src/renderer/src/*"],
      "@tests/*": ["./tests/*"]
    }
  }
}
