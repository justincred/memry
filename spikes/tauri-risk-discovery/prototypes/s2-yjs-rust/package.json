{
  "name": "s2-yjs-rust",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:fixtures": "tsx scripts/generate-yjs-fixtures.ts && (cd src-tauri && cargo run --quiet --bin yrs_fixture_gen)",
    "test:cargo": "cd src-tauri && cargo test --tests",
    "test:node": "vitest run",
    "test:smoke": "playwright test tests/e2e",
    "test:bench": "playwright test tests/bench"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.1",
    "@blocknote/react": "^0.47.1",
    "@blocknote/shadcn": "^0.47.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^2.1.0"
  }
}
